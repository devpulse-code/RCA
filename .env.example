# RCA/.env.example
# ============================================================
#  Copy this file to .env and fill in all values.
#  NEVER commit the real .env file to version control.
# ============================================================

# -----------------------------------------------------------
#  PostgreSQL – database credentials
# -----------------------------------------------------------
POSTGRES_USER=ddm_user
POSTGRES_PASSWORD=change_me_strong_postgres_password
POSTGRES_DB=ddm_db

# -----------------------------------------------------------
#  Redis – internal connection (default is fine)
# -----------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------
#  Meilisearch – master key for search engine
# -----------------------------------------------------------
MEILI_MASTER_KEY=change_me_meili_master_key

# -----------------------------------------------------------
#  DDM application secrets & settings
# -----------------------------------------------------------
# DDM_ENCRYPTION_KEY: 32 random bytes, base64‑encoded.
# Generate with:
#   python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# or:
#   openssl rand -base64 32
DDM_ENCRYPTION_KEY=change_me_32_byte_base64_key

# DDM_SECRET_KEY: used for session signing and other cryptographic operations.
# Generate a long random string (e.g., openssl rand -hex 32)
DDM_SECRET_KEY=change_me_random_secret_key_at_least_64_chars

# -----------------------------------------------------------
#  AI Integration – free‑tier LLM API
# -----------------------------------------------------------
# DDM_AI_PROVIDER: one of "gemini", "together", "groq"
DDM_AI_PROVIDER=gemini
# Google Gemini API key (free tier: https://aistudio.google.com/apikey)
DDM_AI_API_KEY=your_gemini_api_key_here
# Model to use (default: gemini-2.0-flash). Check latest free‑tier model.
DDM_AI_MODEL=gemini-2.0-flash
# Master switch: set to "false" to disable AI entirely
DDM_AI_ENABLED=true

# -----------------------------------------------------------
#  Upload size limits (megabytes)
# -----------------------------------------------------------
DDM_ADMIN_UPLOAD_LIMIT_MB=500
DDM_USER_UPLOAD_LIMIT_MB=100

# -----------------------------------------------------------
#  Environment – "development" or "production"
# -----------------------------------------------------------
DDM_ENVIRONMENT=production

# -----------------------------------------------------------
#  Tika (text extraction) – optional OCR
# -----------------------------------------------------------
# Enable OCR for scanned PDFs (requires Tesseract language data)
TIKA_OCR_ENABLED=false

# -----------------------------------------------------------
#  Domain – used by Nginx for TLS certificate paths and HSTS
# -----------------------------------------------------------
DOMAIN=example.com
# end of RCA/.env.example